[Unit]
Description=Renew Let's Encrypt certificate for Ink Harbor
Wants=network-online.target docker.service
After=network-online.target docker.service

[Service]
Type=oneshot
User=ssy
WorkingDirectory=/home/ssy/web
Environment=CERTBOT_DRY_RUN=0
ExecStart=/home/ssy/web/scripts/renew-letsencrypt.sh

[Install]
WantedBy=multi-user.target

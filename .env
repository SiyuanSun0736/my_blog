BLOG_PRIMARY_DOMAIN=localhost
BLOG_WWW_DOMAIN=www.localhost
BLOG_TLS_CERTS_DIR=./certs
BLOG_CERTBOT_WEBROOT_DIR=./certbot/www
BLOG_TLS_CERT_PATH=/etc/nginx/certs/fullchain.pem
BLOG_TLS_KEY_PATH=/etc/nginx/certs/privkey.pem
BLOG_TLS_AUTO_RELOAD=0
BLOG_TLS_RELOAD_INTERVAL_SECONDS=60
BLOG_WRITE_TOKEN=
REDIS_MAXMEMORY=256mb
MONGODB_WIREDTIGER_CACHE_GB=1
BLOG_API_GOMEMLIMIT=512MiB
BLOG_API_GOGC=100
BLOG_API_BUILD_GOMEMLIMIT=1GiB
BLOG_API_BUILD_GOGC=100
BLOG_API_BUILD_P=4
FRONTEND_BUILD_MAX_OLD_SPACE_SIZE=2048
